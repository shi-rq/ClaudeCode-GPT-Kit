#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
PROXY_DIR="$ROOT_DIR/proxy"
TOKEN_FILE="$ROOT_DIR/data/tokens.json"
LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/chatgpt-codex-proxy.log"
PROXY_PORT="${CHATGPT_CODEX_PROXY_PORT:-19080}"

mkdir -p "$LOG_DIR"

if ! command -v claude >/dev/null 2>&1; then
  printf 'Error: `claude` is not installed or not on PATH.\n' >&2
  printf 'Install Claude Code first, then run scripts/setup.sh again.\n' >&2
  exit 1
fi

if [ ! -f "$TOKEN_FILE" ]; then
  printf 'Missing token file: %s\n' "$TOKEN_FILE" >&2
  printf 'Run `%s/scripts/setup.sh` first.\n' "$ROOT_DIR" >&2
  exit 1
fi

export CHATGPT_CODEX_PROXY_TOKEN_FILE="$TOKEN_FILE"
export PORT="$PROXY_PORT"

if ! python3 -c 'import os, socket; s=socket.socket(); print(s.connect_ex(("127.0.0.1", int(os.environ["PORT"]))))' | grep -qx '0'; then
  (
    cd "$PROXY_DIR"
    nohup npm run start >"$LOG_FILE" 2>&1 &
  )

  for _ in $(seq 1 20); do
    if curl -fsS "http://127.0.0.1:${PROXY_PORT}/health" >/dev/null 2>&1; then
      break
    fi
    sleep 1
  done
fi

if ! curl -fsS "http://127.0.0.1:${PROXY_PORT}/health" >/dev/null 2>&1; then
  printf 'Proxy failed to start. Check %s\n' "$LOG_FILE" >&2
  exit 1
fi

export ANTHROPIC_BASE_URL="http://127.0.0.1:${PROXY_PORT}"
export ANTHROPIC_AUTH_TOKEN="dummy"
unset ANTHROPIC_API_KEY

exec claude "$@"
